@model InkVault.Models.Journal

@{
    ViewData["Title"] = Model?.Title ?? "View Journal";
}

<style>
    .journal-viewer {
        background: linear-gradient(135deg, rgba(102, 126, 234, 0.1) 0%, rgba(118, 75, 162, 0.1) 100%);
        border: 1px solid rgba(102, 126, 234, 0.2);
        border-radius: 12px;
        padding: 40px;
        max-width: 900px;
        margin: 0 auto;
        animation: slideInLeft 0.6s ease;
    }

    .journal-header {
        margin-bottom: 30px;
        padding-bottom: 30px;
        border-bottom: 2px solid rgba(102, 126, 234, 0.2);
    }

    .journal-title {
        font-size: 2.5rem;
        font-weight: 700;
        margin: 0 0 20px 0;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
    }

    .journal-badges {
        display: flex;
        gap: 12px;
        flex-wrap: wrap;
    }

    .journal-tags {
        display: flex;
        gap: 8px;
        flex-wrap: wrap;
        margin-bottom: 20px;
    }

    .tag-badge {
        display: inline-flex;
        align-items: center;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
        padding: 6px 12px;
        border-radius: 16px;
        font-size: 0.85rem;
        font-weight: 500;
        text-transform: lowercase;
        box-shadow: 0 2px 8px rgba(102, 126, 234, 0.3);
        transition: all 0.3s ease;
    }

    .tag-badge:hover {
        transform: translateY(-2px);
        box-shadow: 0 4px 12px rgba(102, 126, 234, 0.4);
    }

    .tag-link {
        text-decoration: none !important;
        color: white !important;
        transition: all 0.3s ease;
    }

    .tag-link:hover {
        color: white !important;
        text-decoration: none !important;
        transform: translateY(-2px);
        box-shadow: 0 4px 12px rgba(102, 126, 234, 0.4);
    }

    .badge {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 8px 16px;
        border-radius: 6px;
        font-weight: 600;
        font-size: 0.9rem;
    }

    .badge-published {
        background: rgba(102, 200, 100, 0.2);
        color: #66c864;
    }

    .badge-private {
        background: rgba(102, 126, 234, 0.2);
        color: #667eea;
    }

    .badge-public {
        background: rgba(240, 147, 251, 0.2);
        color: #f093fb;
    }

    .journal-content {
        background: linear-gradient(135deg, rgba(26, 31, 46, 0.5) 0%, rgba(26, 31, 46, 0.3) 100%);
        border: 1px solid rgba(102, 126, 234, 0.2);
        border-radius: 12px;
        padding: 30px;
        color: var(--text-primary);
        line-height: 1.8;
        font-size: 1.05rem;
        margin-bottom: 30px;
        min-height: 300px;
    }

    /* Light theme styles */
    [data-theme="light"] .journal-viewer {
        background: linear-gradient(135deg, rgba(102, 126, 234, 0.05) 0%, rgba(118, 75, 162, 0.05) 100%);
    }

    [data-theme="light"] .journal-content {
        background: #ffffff;
        border: 1px solid rgba(102, 126, 234, 0.15);
        color: #2c3e50;
    }

    [data-theme="light"] .journal-header {
        border-bottom-color: rgba(102, 126, 234, 0.15);
    }

    [data-theme="light"] .journal-actions {
        border-top-color: rgba(102, 126, 234, 0.15);
    }

    /* Interactions Section */
    .journal-interactions {
        margin-top: 40px;
        padding-top: 30px;
        border-top: 2px solid rgba(102, 126, 234, 0.2);
    }

    .interaction-buttons {
        display: flex;
        gap: 15px;
        margin-bottom: 30px;
    }

    .interaction-btn {
        display: flex;
        align-items: center;
        gap: 8px;
        padding: 12px 20px;
        background: rgba(102, 126, 234, 0.15);
        border: 1px solid rgba(102, 126, 234, 0.3);
        border-radius: 8px;
        color: #667eea;
        cursor: pointer;
        font-weight: 600;
        transition: all 0.3s ease;
        font-size: 1rem;
    }

    .interaction-btn:hover {
        background: rgba(102, 126, 234, 0.3);
        border-color: #667eea;
        transform: translateY(-2px);
    }

    .interaction-btn.liked {
        background: rgba(255, 107, 107, 0.2);
        border-color: #ff6b6b;
        color: #ff6b6b;
    }

    .interaction-btn.liked:hover {
        background: rgba(255, 107, 107, 0.3);
    }

    .interaction-btn.saved {
        background: rgba(255, 193, 7, 0.2);
        border-color: #ffc107;
        color: #ffc107;
    }

    .interaction-btn:disabled {
        opacity: 0.6;
        cursor: not-allowed;
        transform: none !important;
    }

    .comments-section { margin-top: 30px; }

    .comments-title {
        font-size: 1.3rem;
        font-weight: 700;
        margin-bottom: 20px;
        color: var(--text-primary);
    }

    .comment-input-area { margin-bottom: 30px; }

    .comment-textarea {
        width: 100%;
        padding: 15px;
        background: rgba(102, 126, 234, 0.1);
        border: 1px solid rgba(102, 126, 234, 0.3);
        border-radius: 8px;
        color: var(--text-primary);
        font-family: inherit;
        font-size: 1rem;
        resize: vertical;
        min-height: 80px;
        transition: all 0.3s ease;
    }

    .comment-textarea:focus {
        outline: none;
        border-color: #667eea;
        box-shadow: 0 0 0 3px rgba(102, 126, 234, 0.1);
    }

    .comment-submit-actions {
        display: flex;
        gap: 10px;
        margin-top: 10px;
        justify-content: flex-end;
    }

    .btn-post-comment {
        padding: 10px 20px;
        border: none;
        border-radius: 6px;
        cursor: pointer;
        font-weight: 600;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
        transition: all 0.3s ease;
    }

    .btn-post-comment:hover {
        transform: translateY(-2px);
        box-shadow: 0 10px 20px rgba(102, 126, 234, 0.3);
    }

    .btn-cancel-comment {
        padding: 10px 20px;
        border: 1px solid rgba(102, 126, 234, 0.3);
        border-radius: 6px;
        cursor: pointer;
        font-weight: 600;
        background: rgba(102, 126, 234, 0.2);
        color: #667eea;
        transition: all 0.3s ease;
    }

    .btn-cancel-comment:hover { background: rgba(102, 126, 234, 0.3); }

    .comment-item {
        background: rgba(102, 126, 234, 0.08);
        border: 1px solid rgba(102, 126, 234, 0.15);
        border-radius: 8px;
        padding: 15px;
        margin-bottom: 15px;
        transition: all 0.3s ease;
    }

    .comment-item:hover {
        border-color: rgba(102, 126, 234, 0.3);
        background: rgba(102, 126, 234, 0.12);
    }

    .comment-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 10px;
    }

    .comment-author { font-weight: 600; color: var(--text-primary); }

    .comment-meta { display: flex; gap: 15px; align-items: center; }

    .comment-time { font-size: 0.85rem; color: var(--text-secondary); }

    .comment-delete {
        background: rgba(255, 107, 107, 0.2);
        border: none;
        color: #ff6b6b;
        padding: 6px 12px;
        border-radius: 4px;
        cursor: pointer;
        font-size: 0.85rem;
        font-weight: 600;
        transition: all 0.3s ease;
    }

    .comment-delete:hover { background: rgba(255, 107, 107, 0.3); }

    .comment-content { color: var(--text-primary); line-height: 1.6; }

    .no-comments {
        text-align: center;
        padding: 30px;
        color: var(--text-secondary);
        font-style: italic;
    }

    [data-theme="light"] .comment-item {
        background: rgba(102, 126, 234, 0.05);
        border-color: rgba(102, 126, 234, 0.1);
    }

    [data-theme="light"] .comment-textarea {
        background: rgba(102, 126, 234, 0.05);
        color: var(--text-primary);
    }

    /* Toast */
    .toast-container {
        position: fixed;
        top: 20px;
        right: 20px;
        z-index: 9999;
        pointer-events: none;
    }

    @@keyframes slideInRight {
        from { transform: translateX(400px); opacity: 0; }
        to   { transform: translateX(0);     opacity: 1; }
    }

    @@keyframes progressBar {
        from { width: 100%; }
        to   { width: 0%;   }
    }

    .journal-actions {
        display: flex;
        gap: 15px;
        margin-top: 30px;
        padding-top: 30px;
        border-top: 1px solid rgba(102, 126, 234, 0.2);
    }

    .btn-action {
        padding: 12px 25px;
        border: none;
        border-radius: 8px;
        cursor: pointer;
        font-weight: 600;
        font-size: 0.95rem;
        transition: all 0.3s ease;
        display: inline-flex;
        align-items: center;
        gap: 8px;
    }

    .btn-edit {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
    }

    .btn-edit:hover {
        transform: translateY(-2px);
        box-shadow: 0 10px 25px rgba(102, 126, 234, 0.4);
        color: white;
        text-decoration: none;
    }

    .btn-back {
        background: rgba(102, 126, 234, 0.2);
        color: #667eea;
        border: 1px solid rgba(102, 126, 234, 0.3);
    }

    .btn-back:hover {
        background: rgba(102, 126, 234, 0.3);
        color: #667eea;
        text-decoration: none;
    }

    @@media (max-width: 768px) {
        .journal-viewer {
            padding: 20px;
        }

        .journal-title {
            font-size: 1.8rem;
        }

        .journal-actions {
            flex-direction: column;
        }

        .btn-action {
            width: 100%;
            justify-content: center;
        }
    }
</style>

<div class="journal-viewer">
    <div class="journal-header">
        <h1 class="journal-title">@Model?.Title</h1>

        <!-- Referenced From Display (Top - Below Title) -->
        @if (!string.IsNullOrEmpty(Model?.ReferencedDUI))
        {
            <div style="margin-bottom: 20px; padding: 12px 15px; background: rgba(118, 75, 162, 0.1); border-left: 4px solid #764ba2; border-radius: 6px;">
                <div style="display: flex; align-items: center; gap: 10px; color: var(--text-primary); font-size: 0.95rem;">
                    <i class="bi bi-arrow-return-right" style="font-size: 1.1rem; color: #764ba2;"></i>
                    <span style="font-weight: 600; color: var(--text-secondary);">Referenced from:</span>
                    <a href="@Url.Action("ViewByDUI", "Journal", new { dui = Model.ReferencedDUI })" 
                       style="font-family: 'Courier New', monospace; color: #764ba2; font-weight: 600; text-decoration: none; transition: all 0.3s ease;"
                       onmouseover="this.style.textDecoration='underline'; this.style.color='#667eea'"
                       onmouseout="this.style.textDecoration='none'; this.style.color='#764ba2'">
                        @Model.ReferencedDUI
                    </a>
                </div>
            </div>
        }

        <!-- Tags Display -->
        @{
            List<string>? tags = null;
            if (!string.IsNullOrEmpty(Model?.Tags))
            {
                try
                {
                    tags = System.Text.Json.JsonSerializer.Deserialize<List<string>>(Model.Tags);
                }
                catch
                {
                    tags = null;
                }
            }
        }

        @if (tags != null && tags.Any())
        {
            <div class="journal-tags">
                @foreach (var tag in tags)
                {
                    <a href="@Url.Action("Index", "Explore", new { tag = tag })" class="tag-badge tag-link">@tag</a>
                }
            </div>
        }

        <div class="journal-badges">
            <span class="badge badge-published">
                <i class="bi bi-cloud-check"></i>
                Published
            </span>
            <span class="badge @(Model?.PrivacyLevel == InkVault.Models.PrivacyLevel.Private ? "badge-private" : "badge-public")">
                <i class="bi @(Model?.PrivacyLevel == InkVault.Models.PrivacyLevel.Private ? "bi-lock" : "bi-globe")"></i>
                @(Model?.PrivacyLevel == InkVault.Models.PrivacyLevel.Private ? "Private" : "Public")
            </span>
        </div>
    </div>

    <!-- Abstract Section (if exists) -->
    @if (!string.IsNullOrWhiteSpace(Model?.Abstract))
    {
        <div style="margin-bottom: 30px; padding: 20px; background: rgba(102, 126, 234, 0.08); border-left: 4px solid #667eea; border-radius: 8px;">
            <h3 style="font-size: 1.2rem; font-weight: 600; margin-bottom: 12px; color: var(--text-primary);">
                <i class="bi bi-file-text"></i> Abstract
            </h3>
            <p style="color: var(--text-primary); line-height: 1.8;">@Model.Abstract</p>
        </div>
    }

    <!-- Journal Content -->
    @if (!string.IsNullOrWhiteSpace(Model?.Content))
    {
        <div class="journal-content">
            @Html.Raw(Model?.Content)
        </div>
    }
    else if (!string.IsNullOrWhiteSpace(Model?.Abstract))
    {
        <!-- Only Abstract exists - Show Request Button -->
        var currentUserId = User?.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
        var isOwner = Model.UserId == currentUserId;

        if (!isOwner)
        {
            <div style="margin-top: 30px; padding: 30px; text-align: center; background: rgba(102, 126, 234, 0.05); border: 2px dashed rgba(102, 126, 234, 0.3); border-radius: 12px;">
                <i class="bi bi-file-lock2" style="font-size: 3rem; color: #667eea; margin-bottom: 15px; display: block;"></i>
                <h3 style="font-size: 1.4rem; margin-bottom: 10px; color: var(--text-primary);">Full Content Restricted</h3>
                <p style="color: var(--text-secondary); margin-bottom: 20px;">The full text of this journal is not publicly available. You can request access from the author.</p>

                <form asp-controller="Journal" asp-action="RequestFullText" method="post" style="display: inline;">
                    <input type="hidden" name="journalId" value="@Model.JournalId" />
                    @Html.AntiForgeryToken()
                    <button type="submit" id="requestButton" class="btn-action btn-edit" style="display: inline-flex; align-items: center; gap: 8px;">
                        <i class="bi bi-envelope-paper"></i>
                        <span id="requestButtonText">Request to View Full Text</span>
                    </button>
                </form>

                <script>
                    // Check if user already requested
                    fetch('@Url.Action("HasRequestedFullText", "Journal")?journalId=@Model.JournalId')
                        .then(response => response.json())
                        .then(data => {
                            if (data.hasRequested) {
                                const button = document.getElementById('requestButton');
                                button.disabled = true;
                                button.style.opacity = '0.6';
                                button.style.cursor = 'not-allowed';
                                document.getElementById('requestButtonText').textContent = 'Access Already Requested';
                            }
                        });
                </script>
            </div>
        }
    }

    <!-- DUI Display at Bottom (Only for Public Journals) -->
    @if (Model?.PrivacyLevel == InkVault.Models.PrivacyLevel.Public && !string.IsNullOrEmpty(Model.DUI))
    {
        <div style="margin-top: 30px; padding: 15px; background: rgba(102, 126, 234, 0.1); border-left: 4px solid #667eea; border-radius: 6px;">
            <div style="display: flex; align-items: center; gap: 10px; color: var(--text-primary);">
                <i class="bi bi-fingerprint" style="font-size: 1.2rem; color: #667eea;"></i>
                <span style="font-weight: 600;">Document ID:</span>
                <span style="font-family: 'Courier New', monospace; color: #667eea; font-weight: 600; font-size: 1.05rem;">@Model.DUI</span>
            </div>
        </div>
    }

    <!-- Interactions Section -->
    <div class="journal-interactions">
        <div class="interaction-buttons">
            <button class="interaction-btn" id="likeBtn" onclick="toggleLike(@Model!.JournalId)">
                <i class="bi bi-heart"></i> <span id="likeBtnText">Like</span> <span id="likeCount">(@(Model.Likes?.Count ?? 0))</span>
            </button>
            <button class="interaction-btn" onclick="toggleCommentInput()">
                <i class="bi bi-chat-dots"></i> Comment <span>(@(Model.Comments?.Count ?? 0))</span>
            </button>
            @{
                var viewerUserId = User?.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
            }
            @if (Model?.UserId != viewerUserId)
            {
                <button class="interaction-btn" id="saveBtn" onclick="toggleSaveJournal(@Model!.JournalId)">
                    <i class="bi bi-bookmark"></i> <span id="saveBtnText">Save</span>
                </button>
            }
        </div>

        <div class="comments-section">
            <h3 class="comments-title"><i class="bi bi-chat-dots"></i> Comments</h3>

            <div class="comment-input-area" id="commentInputArea" style="display:none;">
                <textarea class="comment-textarea" id="commentText" placeholder="Share your thoughts..."></textarea>
                <div class="comment-submit-actions">
                    <button class="btn-post-comment" onclick="submitComment(@Model!.JournalId)">Post Comment</button>
                    <button class="btn-cancel-comment" onclick="toggleCommentInput()">Cancel</button>
                </div>
            </div>

            <div id="commentsList">
                @if (Model?.Comments != null && Model.Comments.Any())
                {
                    @foreach (var comment in Model.Comments.OrderByDescending(c => c.CreatedAt))
                    {
                        <div class="comment-item" id="comment-@comment.Id">
                            <div class="comment-header">
                                <div class="comment-author">@comment.User?.FirstName @comment.User?.LastName</div>
                                <div class="comment-meta">
                                    <span class="comment-time"><time datetime="@comment.CreatedAt.ToString("o")"></time></span>
                                    @if (User.Identity?.Name == comment.User?.UserName || Model.UserId == viewerUserId)
                                    {
                                        <button class="comment-delete" onclick="deleteComment(@comment.Id)">Delete</button>
                                    }
                                </div>
                            </div>
                            <div class="comment-content">@comment.Content</div>
                        </div>
                    }
                }
                else
                {
                    <div class="no-comments">No comments yet. Be the first to comment!</div>
                }
            </div>
        </div>
    </div>

    <!-- Actions -->
    <div class="journal-actions">
        @{
            var userId = User?.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
            var fromBrowse = ViewBag.FromBrowse ?? false;
            var fromFeed = ViewBag.FromFeed ?? false;
            var fromLibrary = ViewBag.FromLibrary ?? false;
            var fromUserProfile = ViewBag.FromUserProfile ?? false;
            var userProfileId = ViewBag.UserProfileId as string;
            var backToFriends = ViewBag.BackToFriends ?? false;
            var topicName = ViewBag.TopicName ?? "";
        }
        
        @if (fromLibrary)
        {
            <!-- Show back to My Library button when coming from library -->
            <a href="@Url.Action("Index", "Journal", new { controller = "Journal", action = "Library" })" class="btn-action btn-back">
                <i class="bi bi-arrow-left"></i> Back to My Library
            </a>
        }
        else if (fromUserProfile && backToFriends)
        {
            <!-- Show back to Friends button when coming from Friends → Profile → Journals → Journal -->
            <a href="@Url.Action("Index", "Friends")" class="btn-action btn-back">
                <i class="bi bi-arrow-left"></i> Back to Friends
            </a>
        }
        else if (fromUserProfile && !string.IsNullOrEmpty(userProfileId))
        {
            <!-- Show back to User Journals button when coming from user profile -->
            <a href="@Url.Action("ViewUserJournals", "Profile", new { userId = userProfileId })" class="btn-action btn-back">
                <i class="bi bi-arrow-left"></i> Back to User Journals
            </a>
        }
        else if (fromFeed)
        {
            <!-- Show only Friends Feed button when coming from feed -->
            <a href="@Url.Action("Index", "Feed")" class="btn-action btn-back">
                <i class="bi bi-arrow-left"></i> Back to Friends Feed
            </a>
        }
        else if (fromBrowse && !string.IsNullOrEmpty(topicName))
        {
            <!-- Show only Browse by Topic button when coming from browse/topic -->
            <a href="@Url.Action("ViewByTopic", "Topic", new { topicName = topicName })" class="btn-action btn-back">
                <i class="bi bi-arrow-left"></i> Back to Browse by Topic
            </a>
        }
        else if (Model?.UserId == userId)
        {
            <!-- Show My Journals and Edit for own journals when not from browse -->
            <a href="@Url.Action("MyJournals", "Journal")" class="btn-action btn-back">
                <i class="bi bi-arrow-left"></i> Back to My Journals
            </a>

            <a href="@Url.Action("Edit", "Journal", new { id = Model.JournalId })" class="btn-action btn-edit">
                <i class="bi bi-pencil"></i> Edit Journal
            </a>
        }
        else
        {
            <!-- For other users viewing, show generic back button -->
            <a href="@Url.Action("Index", "Explore")" class="btn-action btn-back">
                <i class="bi bi-arrow-left"></i> Back to Explore
            </a>
        }
    </div>
</div>

<!-- Toast Container -->
<div class="toast-container" id="toastContainer"></div>

@Html.AntiForgeryToken()

<script>
    document.addEventListener('DOMContentLoaded', function () {
        initializeLikeState();
        initializeSaveState();
        // Convert all <time> elements to local date
        document.querySelectorAll('time[datetime]').forEach(function (el) {
            var utc = new Date(el.getAttribute('datetime'));
            if (!isNaN(utc)) el.textContent = utc.toLocaleDateString(undefined, { month: 'short', day: 'numeric', year: 'numeric' });
        });
    });

    const journalId = @Model!.JournalId;

    function initializeLikeState() {
        fetch(`/api/interaction/likes/${journalId}`)
            .then(r => r.json())
            .then(data => {
                const btn = document.getElementById('likeBtn');
                const txt = document.getElementById('likeBtnText');
                if (!btn || !txt) return;
                if (data.userLiked) {
                    btn.classList.add('liked');
                    txt.textContent = 'Unlike';
                } else {
                    btn.classList.remove('liked');
                    txt.textContent = 'Like';
                }
            })
            .catch(() => {});
    }

    function initializeSaveState() {
        const saveBtn = document.getElementById('saveBtn');
        if (!saveBtn) return;
        fetch(`/api/SavedJournal/check/${journalId}`)
            .then(r => r.json())
            .then(data => {
                const txt = document.getElementById('saveBtnText');
                if (data.isSaved) {
                    saveBtn.classList.add('saved');
                    if (txt) txt.textContent = 'Saved';
                } else {
                    saveBtn.classList.remove('saved');
                    if (txt) txt.textContent = 'Save';
                }
            })
            .catch(() => {});
    }

    function toggleLike(id) {
        fetch(`/api/interaction/like/${id}`, {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
                'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]')?.value || ''
            }
        })
        .then(r => r.json())
        .then(data => {
            const btn = document.getElementById('likeBtn');
            const txt = document.getElementById('likeBtnText');
            const count = document.getElementById('likeCount');
            if (data.liked) {
                btn.classList.add('liked');
                txt.textContent = 'Unlike';
                showToast('Liked this journal!', 'success');
            } else {
                btn.classList.remove('liked');
                txt.textContent = 'Like';
                showToast('Unliked this journal', 'info');
            }
            count.textContent = `(${data.likeCount})`;
        })
        .catch(() => showToast('Failed to update like', 'error'));
    }

    function toggleSaveJournal(id) {
        const saveBtn = document.getElementById('saveBtn');
        const saveBtnText = document.getElementById('saveBtnText');
        if (!saveBtn) { showToast('You cannot save your own journal!', 'warning'); return; }

        const isSaved = saveBtn.classList.contains('saved');
        const url = isSaved ? `/api/SavedJournal/unsave/${id}` : `/api/SavedJournal/save/${id}`;
        saveBtn.disabled = true;
        saveBtnText.textContent = isSaved ? 'Removing...' : 'Saving...';

        const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value;
        fetch(url, {
            method: isSaved ? 'DELETE' : 'POST',
            headers: {
                'Content-Type': 'application/json',
                'RequestVerificationToken': token || ''
            }
        })
        .then(r => { if (!r.ok) throw new Error(r.status); return r.json(); })
        .then(() => {
            if (isSaved) {
                saveBtn.classList.remove('saved');
                saveBtnText.textContent = 'Save';
                showToast('Removed from your library', 'warning');
            } else {
                saveBtn.classList.add('saved');
                saveBtnText.textContent = 'Saved';
                showToast('Saved to your library!', 'success');
            }
        })
        .catch(() => {
            saveBtnText.textContent = isSaved ? 'Saved' : 'Save';
            showToast('Failed to update save', 'error');
        })
        .finally(() => { saveBtn.disabled = false; });
    }

    function toggleCommentInput() {
        const area = document.getElementById('commentInputArea');
        area.style.display = area.style.display === 'none' ? 'block' : 'none';
        if (area.style.display === 'block') document.getElementById('commentText').focus();
    }

    function submitComment(id) {
        const text = document.getElementById('commentText').value.trim();
        if (!text) { showToast('Please enter a comment', 'error'); return; }

        fetch('/api/interaction/comment', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
                'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]')?.value || ''
            },
            body: JSON.stringify({ journalId: id, content: text })
        })
        .then(r => r.json())
        .then(data => {
            const list = document.getElementById('commentsList');
            const noComments = list.querySelector('.no-comments');
            if (noComments) noComments.remove();

            const el = document.createElement('div');
            el.className = 'comment-item';
            el.id = `comment-${data.id}`;
            el.innerHTML = `
                <div class="comment-header">
                    <div class="comment-author">${data.authorName}</div>
                    <div class="comment-meta">
                        <span class="comment-time"><time datetime="${data.createdAt}"></time></span>
                        <button class="comment-delete" onclick="deleteComment(${data.id})">Delete</button>
                    </div>
                </div>
                <div class="comment-content">${data.content}</div>`;

            list.insertBefore(el, list.firstChild);
            el.querySelectorAll('time[datetime]').forEach(function (t) {
                var utc = new Date(t.getAttribute('datetime'));
                if (!isNaN(utc)) t.textContent = utc.toLocaleDateString(undefined, { month: 'short', day: 'numeric', year: 'numeric' });
            });

            document.getElementById('commentText').value = '';
            document.getElementById('commentInputArea').style.display = 'none';
            showToast('Comment posted!', 'success');
        })
        .catch(() => showToast('Failed to post comment', 'error'));
    }

    function deleteComment(commentId) {
        if (!confirm('Delete this comment?')) return;
        fetch(`/api/interaction/comment/${commentId}`, {
            method: 'DELETE',
            headers: {
                'Content-Type': 'application/json',
                'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]')?.value || ''
            }
        })
        .then(r => r.json())
        .then(() => {
            const el = document.getElementById(`comment-${commentId}`);
            if (el) el.remove();
            showToast('Comment deleted', 'success');
        })
        .catch(() => showToast('Failed to delete comment', 'error'));
    }

    function showToast(message, type = 'info') {
        const container = document.getElementById('toastContainer');
        const id = 'toast-' + Date.now();
        const colors = {
            success: 'linear-gradient(135deg,#10b981 0%,#059669 100%)',
            error:   'linear-gradient(135deg,#ef4444 0%,#dc2626 100%)',
            warning: 'linear-gradient(135deg,#f59e0b 0%,#d97706 100%)',
            info:    'linear-gradient(135deg,#3b82f6 0%,#2563eb 100%)'
        };
        const icons = { success:'bi-check-circle', error:'bi-exclamation-circle', warning:'bi-exclamation-triangle', info:'bi-info-circle' };
        const toast = document.createElement('div');
        toast.id = id;
        toast.style.cssText = `background:${colors[type]||colors.info};color:white;padding:16px 24px;border-radius:8px;margin-bottom:12px;box-shadow:0 10px 30px rgba(0,0,0,.2);animation:slideInRight .4s ease;display:flex;align-items:center;gap:12px;font-weight:600;max-width:400px;min-width:300px;pointer-events:auto;position:relative;overflow:hidden;`;
        toast.innerHTML = `<i class="bi ${icons[type]||icons.info}" style="font-size:1.2rem;flex-shrink:0;"></i><span style="flex:1;">${message}</span><button onclick="document.getElementById('${id}')?.remove()" style="background:none;border:none;color:white;font-size:1.4rem;cursor:pointer;padding:0;opacity:.7;">×</button><div style="position:absolute;bottom:0;left:0;height:4px;background:rgba(255,255,255,.3);width:100%;animation:progressBar 4s linear;"></div>`;
        container.appendChild(toast);
        setTimeout(() => { toast.style.animation = 'slideInRight .3s ease reverse'; setTimeout(() => toast.remove(), 300); }, 4000);
    }
</script>
