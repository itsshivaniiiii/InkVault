@model IEnumerable<InkVault.ViewModels.ReadingHistoryItemViewModel>

@{
    ViewData["Title"] = "Reading History";
    var items = Model.ToList();
}

<style>
    .history-container {
        max-width: 1200px;
        margin: 0 auto;
        padding: 40px 20px;
        animation: fadeInUp 0.8s ease;
    }

    .page-header {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        gap: 20px;
        margin-bottom: 40px;
        padding-bottom: 25px;
        border-bottom: 2px solid rgba(102, 126, 234, 0.2);
        flex-wrap: wrap;
    }

    .page-header h1 {
        font-size: 2rem;
        font-weight: 700;
        margin: 0 0 6px 0;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
        display: flex;
        align-items: center;
        gap: 12px;
    }

    .page-header p {
        color: var(--text-secondary);
        margin: 0;
        font-size: 1rem;
    }

    .count-badge {
        background: rgba(102, 126, 234, 0.15);
        color: #667eea;
        padding: 8px 18px;
        border-radius: 20px;
        font-size: 0.9rem;
        font-weight: 600;
        white-space: nowrap;
        align-self: center;
    }

    .back-btn {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 10px 20px;
        background: rgba(102, 126, 234, 0.2);
        color: #667eea;
        border: 1px solid rgba(102, 126, 234, 0.3);
        border-radius: 6px;
        text-decoration: none;
        font-weight: 600;
        transition: all 0.3s ease;
        margin-bottom: 30px;
    }

    .back-btn:hover {
        background: rgba(102, 126, 234, 0.3);
        color: #667eea;
        text-decoration: none;
    }

    .history-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
        gap: 22px;
    }

    .history-card {
        background: linear-gradient(135deg, rgba(26, 31, 46, 0.8) 0%, rgba(26, 31, 46, 0.6) 100%);
        border: 1px solid rgba(102, 126, 234, 0.2);
        border-radius: 12px;
        padding: 22px;
        display: flex;
        flex-direction: column;
        gap: 14px;
        transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    }

    .history-card:hover {
        transform: translateY(-6px);
        border-color: rgba(102, 126, 234, 0.5);
        box-shadow: 0 18px 36px rgba(102, 126, 234, 0.18);
    }

    .history-card-top {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        gap: 12px;
    }

    .journal-title {
        font-size: 1.15rem;
        font-weight: 700;
        color: var(--text-primary);
        margin: 0 0 6px 0;
        line-height: 1.4;
    }

    .author-line {
        font-size: 0.85rem;
        color: var(--text-secondary);
        display: flex;
        align-items: center;
        gap: 5px;
    }

    .viewed-date {
        font-size: 0.8rem;
        color: var(--text-secondary);
        display: flex;
        align-items: center;
        gap: 5px;
        white-space: nowrap;
        flex-shrink: 0;
    }

    .history-badges {
        display: flex;
        flex-wrap: wrap;
        gap: 6px;
        align-items: center;
    }

    .own-badge {
        background: rgba(102, 200, 100, 0.2);
        color: #66c864;
        padding: 3px 9px;
        border-radius: 12px;
        font-size: 0.75rem;
        font-weight: 600;
        display: inline-flex;
        align-items: center;
        gap: 4px;
    }

    .anon-badge {
        background: rgba(163, 135, 236, 0.2);
        color: #a387ec;
        padding: 3px 9px;
        border-radius: 12px;
        font-size: 0.75rem;
        font-weight: 600;
        display: inline-flex;
        align-items: center;
        gap: 4px;
    }

    .topic-badge {
        background: rgba(102, 126, 234, 0.15);
        color: #667eea;
        padding: 3px 9px;
        border-radius: 12px;
        font-size: 0.78rem;
        font-weight: 600;
    }

    .reading-time-badge {
        background: rgba(240, 147, 251, 0.15);
        color: #f093fb;
        padding: 3px 9px;
        border-radius: 12px;
        font-size: 0.78rem;
        font-weight: 600;
        display: inline-flex;
        align-items: center;
        gap: 4px;
    }

    .privacy-badge {
        padding: 3px 9px;
        border-radius: 12px;
        font-size: 0.75rem;
        font-weight: 600;
        display: inline-flex;
        align-items: center;
        gap: 4px;
    }

    .privacy-public {
        background: rgba(240, 147, 251, 0.15);
        color: #f093fb;
    }

    .privacy-friendsonly {
        background: rgba(102, 126, 234, 0.15);
        color: #667eea;
    }

    .privacy-private {
        background: rgba(102, 126, 234, 0.15);
        color: #667eea;
    }

    .view-journal-btn {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
        padding: 9px 18px;
        border: none;
        border-radius: 6px;
        text-decoration: none;
        font-weight: 600;
        font-size: 0.88rem;
        transition: all 0.3s ease;
        display: inline-flex;
        align-items: center;
        gap: 6px;
        align-self: flex-start;
    }

    .view-journal-btn:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 16px rgba(102, 126, 234, 0.4);
        color: white;
        text-decoration: none;
    }

    .empty-state {
        text-align: center;
        padding: 80px 40px;
        background: rgba(102, 126, 234, 0.05);
        border: 1px dashed rgba(102, 126, 234, 0.2);
        border-radius: 12px;
    }

    .empty-state i {
        font-size: 4rem;
        color: var(--text-secondary);
        opacity: 0.4;
        margin-bottom: 20px;
        display: block;
    }

    .empty-state h3 {
        color: var(--text-primary);
        font-size: 1.5rem;
        margin-bottom: 10px;
    }

    .empty-state p {
        color: var(--text-secondary);
        margin-bottom: 25px;
    }

    .explore-btn {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
        padding: 12px 24px;
        border-radius: 8px;
        text-decoration: none;
        font-weight: 600;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        transition: all 0.3s ease;
    }

    .explore-btn:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 20px rgba(102, 126, 234, 0.4);
        color: white;
        text-decoration: none;
    }

    [data-theme="light"] .history-card {
        background: #ffffff;
        border-color: rgba(102, 126, 234, 0.15);
    }

    @@keyframes fadeInUp {
        from { opacity: 0; transform: translateY(20px); }
        to   { opacity: 1; transform: translateY(0); }
    }

    @@media (max-width: 768px) {
        .history-grid {
            grid-template-columns: 1fr;
        }

        .page-header h1 {
            font-size: 1.5rem;
        }
    }
</style>

<div class="history-container">
    <a href="@Url.Action("MyJournals", "Journal")" class="back-btn">
        <i class="bi bi-arrow-left"></i> Back to My Journals
    </a>

    <div class="page-header">
        <div>
            <h1>
                <i class="bi bi-clock-history"></i> Reading History
            </h1>
            <p>Every published journal you've opened</p>
        </div>
        <span class="count-badge">@items.Count journal@(items.Count != 1 ? "s" : "") read</span>
    </div>

    @if (items.Any())
    {
        <div class="history-grid">
            @foreach (var item in items)
            {
                <div class="history-card">
                    <div class="history-card-top">
                        <div>
                            <h3 class="journal-title">@item.Title</h3>
                            <div class="author-line">
                                @if (item.IsOwn)
                                {
                                    <span class="own-badge"><i class="bi bi-person-fill"></i> Your Journal</span>
                                }
                                else if (item.IsAnonymous)
                                {
                                    <span class="anon-badge"><i class="bi bi-incognito"></i> Anonymous</span>
                                }
                                else
                                {
                                    <i class="bi bi-person"></i>
                                    <span>@item.AuthorName</span>
                                }
                            </div>
                        </div>
                        <div class="viewed-date">
                            <i class="bi bi-calendar-check"></i>
                            <time datetime="@item.ViewedAt.ToString("o")"></time>
                        </div>
                    </div>

                    <div class="history-badges">
                        @if (!string.IsNullOrEmpty(item.Topic))
                        {
                            <span class="topic-badge">#@item.Topic</span>
                        }
                        <span class="reading-time-badge">
                            <i class="bi bi-clock"></i> @item.ReadingTimeMinutes min read
                        </span>
                        <span class="privacy-badge privacy-@item.PrivacyLevel.ToString().ToLower()">
                            @if (item.PrivacyLevel == InkVault.Models.PrivacyLevel.Public)
                            {
                                <i class="bi bi-globe"></i><span>Public</span>
                            }
                            else if (item.PrivacyLevel == InkVault.Models.PrivacyLevel.FriendsOnly)
                            {
                                <i class="bi bi-people-fill"></i><span>Friends</span>
                            }
                            else
                            {
                                <i class="bi bi-lock-fill"></i><span>Private</span>
                            }
                        </span>
                    </div>

                    <a href="@Url.Action("View", "Journal", new { id = item.JournalId })" class="view-journal-btn">
                        <i class="bi bi-eye"></i> Read Again
                    </a>
                </div>
            }
        </div>
    }
    else
    {
        <div class="empty-state">
            <i class="bi bi-clock-history"></i>
            <h3>No Reading History Yet</h3>
            <p>Every published journal you open will appear here.</p>
            <a href="@Url.Action("Index", "Explore")" class="explore-btn">
                <i class="bi bi-compass"></i> Explore Journals
            </a>
        </div>
    }
</div>
