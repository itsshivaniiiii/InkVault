@model InkVault.ViewModels.ProfileViewModel

@{
    ViewData["Title"] = "My Profile";
}

<style>
    .profile-container {
        max-width: 900px;
        margin: 0 auto;
        animation: fadeInUp 0.8s ease;
    }

    .profile-header {
        display: flex;
        align-items: center;
        gap: 20px;
        margin-bottom: 40px;
        padding: 30px;
        background: linear-gradient(135deg, rgba(102, 126, 234, 0.1) 0%, rgba(118, 75, 162, 0.1) 100%);
        border: 1px solid rgba(102, 126, 234, 0.2);
        border-radius: 12px;
    }

    .profile-avatar-wrapper {
        position: relative;
    }

    .profile-avatar {
        width: 120px;
        height: 120px;
        border-radius: 50%;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 2rem;
        font-weight: 700;
        color: white;
        flex-shrink: 0;
        border: 3px solid rgba(102, 126, 234, 0.3);
        cursor: pointer;
        transition: all 0.3s ease;
        position: relative;
    }

    .profile-avatar:hover {
        transform: scale(1.05);
        border-color: #667eea;
        box-shadow: 0 0 20px rgba(102, 126, 234, 0.4);
    }

    .profile-avatar img {
        width: 100%;
        height: 100%;
        border-radius: 50%;
        object-fit: cover;
    }

    .profile-avatar-overlay {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        border-radius: 50%;
        background: rgba(0, 0, 0, 0.3);
        display: flex;
        align-items: center;
        justify-content: center;
        opacity: 0;
        transition: opacity 0.3s ease;
    }

    .profile-avatar:hover .profile-avatar-overlay {
        opacity: 1;
    }

    .profile-avatar-overlay i {
        font-size: 1.5rem;
        color: white;
    }

    #profilePictureInput {
        display: none;
    }

    .remove-picture-btn {
        position: absolute;
        bottom: -10px;
        right: -10px;
        width: 40px;
        height: 40px;
        background: #ff6b6b;
        border: 2px solid white;
        border-radius: 50%;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        font-size: 1.2rem;
        transition: all 0.3s ease;
        opacity: 0;
    }

    .profile-avatar-wrapper:hover .remove-picture-btn {
        opacity: 1;
    }

    .remove-picture-btn:hover {
        background: #ff5252;
        transform: scale(1.1);
    }

    .profile-info h2 {
        font-size: 1.8rem;
        margin: 0 0 10px 0;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
    }

    .profile-info p {
        margin: 5px 0;
        color: var(--text-secondary);
    }

    .section-card {
        background: linear-gradient(135deg, rgba(102, 126, 234, 0.1) 0%, rgba(118, 75, 162, 0.1) 100%);
        border: 1px solid rgba(102, 126, 234, 0.2);
        border-radius: 12px;
        padding: 25px;
        margin-bottom: 25px;
    }

    .section-title {
        font-size: 1.3rem;
        font-weight: 700;
        margin-bottom: 20px;
        padding-bottom: 15px;
        border-bottom: 2px solid rgba(102, 126, 234, 0.2);
        color: var(--text-primary);
    }

    .form-group {
        margin-bottom: 20px;
    }

    .form-group label {
        display: block;
        font-weight: 600;
        margin-bottom: 8px;
        color: var(--text-primary);
    }

    .form-control, .form-select {
        background: linear-gradient(135deg, rgba(26, 31, 46, 0.9) 0%, rgba(26, 31, 46, 0.8) 100%);
        border: 1px solid rgba(102, 126, 234, 0.3);
        color: var(--text-primary);
        border-radius: 8px;
        padding: 12px 15px;
        width: 100%;
        transition: all 0.3s ease;
    }

    .form-control:focus, .form-select:focus {
        border-color: #667eea;
        box-shadow: 0 0 0 0.2rem rgba(102, 126, 234, 0.25);
    }

    .form-row {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 20px;
    }

    .theme-toggle {
        display: flex;
        gap: 15px;
        align-items: center;
    }

    .theme-option {
        display: flex;
        align-items: center;
        gap: 8px;
        padding: 12px 20px;
        background: rgba(102, 126, 234, 0.2);
        border: 2px solid rgba(102, 126, 234, 0.3);
        border-radius: 8px;
        cursor: pointer;
        transition: all 0.3s ease;
    }

    .theme-option.active {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        border-color: #667eea;
        color: white;
    }

    .theme-option input {
        display: none;
    }

    .btn-primary, .btn-danger {
        padding: 12px 25px;
        border: none;
        border-radius: 8px;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.3s ease;
        display: inline-flex;
        align-items: center;
        gap: 8px;
    }

    .btn-primary {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
    }

    .btn-primary:hover {
        transform: translateY(-2px);
        box-shadow: 0 10px 25px rgba(102, 126, 234, 0.4);
        color: white;
        text-decoration: none;
    }

    .btn-danger {
        background: rgba(255, 107, 107, 0.2);
        color: #ff6b6b;
        border: 1px solid rgba(255, 107, 107, 0.3);
    }

    .btn-danger:hover {
        background: rgba(255, 107, 107, 0.3);
        color: #ff6b6b;
        text-decoration: none;
    }

    .form-actions {
        display: flex;
        gap: 15px;
        margin-top: 25px;
    }

    .stat-item {
        padding: 15px;
        background: rgba(102, 126, 234, 0.1);
        border-radius: 8px;
        text-align: left;
    }

    .stat-label {
        color: var(--text-secondary);
        font-size: 0.9rem;
        margin-bottom: 5px;
    }

    .stat-value {
        font-size: 1rem;
        font-weight: 700;
        color: var(--text-primary);
        word-break: break-all;
    }

    @@media (max-width: 768px) {
        .profile-header {
            flex-direction: column;
            text-align: center;
        }

        .form-row {
            grid-template-columns: 1fr;
        }

        .form-actions {
            flex-direction: column;
        }

        .theme-toggle {
            flex-direction: column;
            width: 100%;
        }

        .theme-option {
            width: 100%;
            justify-content: center;
        }
    }

    /* Light Theme Styles for Profile */
    [data-theme="light"] .profile-container {
        color: var(--text-primary);
    }

    [data-theme="light"] .form-control,
    [data-theme="light"] .form-select {
        background: #ffffff !important;
        border-color: rgba(102, 126, 234, 0.3) !important;
        color: var(--text-primary) !important;
    }

    [data-theme="light"] .form-control:focus,
    [data-theme="light"] .form-select:focus {
        border-color: #667eea !important;
        box-shadow: 0 0 0 0.2rem rgba(102, 126, 234, 0.25) !important;
    }

    [data-theme="light"] .form-group label {
        color: var(--text-primary) !important;
    }

    [data-theme="light"] .stat-item {
        background: rgba(102, 126, 234, 0.05) !important;
    }

    [data-theme="light"] .section-card {
        background: linear-gradient(135deg, rgba(102, 126, 234, 0.05) 0%, rgba(118, 75, 162, 0.05) 100%);
        border-color: rgba(102, 126, 234, 0.15) !important;
    }

    [data-theme="light"] .section-title {
        color: var(--text-primary) !important;
        border-bottom-color: rgba(102, 126, 234, 0.15) !important;
    }

    .back-btn {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 10px 20px;
        background: rgba(102, 126, 234, 0.2);
        color: #667eea;
        border: 1px solid rgba(102, 126, 234, 0.3);
        border-radius: 6px;
        text-decoration: none;
        font-weight: 600;
        transition: all 0.3s ease;
        margin-bottom: 30px;
    }

    .back-btn:hover {
        background: rgba(102, 126, 234, 0.3);
        color: #667eea;
        text-decoration: none;
    }

    .pinned-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
        gap: 18px;
    }

    .pinned-card {
        background: linear-gradient(135deg, rgba(102, 126, 234, 0.1) 0%, rgba(118, 75, 162, 0.1) 100%);
        border: 1px solid rgba(102, 126, 234, 0.25);
        border-radius: 10px;
        padding: 18px;
        transition: all 0.3s ease;
    }

    .pinned-card:hover {
        border-color: rgba(102, 126, 234, 0.5);
        box-shadow: 0 8px 20px rgba(102, 126, 234, 0.15);
        transform: translateY(-3px);
    }

    .pinned-card-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        gap: 10px;
        margin-bottom: 10px;
    }

    .pinned-card-title {
        font-size: 1rem;
        font-weight: 700;
        color: var(--text-primary);
        margin: 0;
        flex: 1;
    }

    .unpin-btn {
        background: none;
        border: none;
        color: rgba(255, 107, 107, 0.7);
        cursor: pointer;
        padding: 2px 6px;
        font-size: 1.1rem;
        border-radius: 4px;
        transition: all 0.2s ease;
        flex-shrink: 0;
    }

    .unpin-btn:hover {
        color: #ff6b6b;
        background: rgba(255, 107, 107, 0.1);
    }

    .pinned-topic {
        display: inline-block;
        font-size: 0.78rem;
        color: #667eea;
        background: rgba(102, 126, 234, 0.1);
        border-radius: 10px;
        padding: 2px 8px;
        margin-bottom: 10px;
    }

    .pinned-preview {
        font-size: 0.88rem;
        color: var(--text-secondary);
        line-height: 1.5;
        margin-bottom: 12px;
        display: -webkit-box;
        -webkit-line-clamp: 3;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    .pinned-card-footer {
        display: flex;
        justify-content: space-between;
        align-items: center;
        font-size: 0.8rem;
        color: var(--text-secondary);
    }

    .pinned-empty {
        text-align: center;
        padding: 25px;
        background: rgba(102, 126, 234, 0.05);
        border-radius: 8px;
        border: 1px dashed rgba(102, 126, 234, 0.3);
    }

    .pin-counter {
        font-size: 0.88rem;
        color: var(--text-secondary);
        margin-bottom: 18px;
    }

    [data-theme="light"] .pinned-card {
        background: #ffffff;
        border-color: rgba(102, 126, 234, 0.15);
    }

</style>

<div class="profile-container">
    <a href="@Url.Action("Index", "Home")" class="back-btn">
        <i class="bi bi-arrow-left"></i> Back to Dashboard
    </a>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show">
            @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show">
            @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <!-- Profile Header -->
    <div class="profile-header">
        <div class="profile-avatar-wrapper">
            <label for="profilePictureInput" class="profile-avatar">
                @if (!string.IsNullOrEmpty(Model?.ProfilePictureUrl))
                {
                    <img src="@Model.ProfilePictureUrl" alt="Profile Picture" />
                }
                else
                {
                    <span>@Model?.FirstName?[0]@Model?.LastName?[0]</span>
                }
                <div class="profile-avatar-overlay">
                    <i class="bi bi-camera-fill"></i>
                </div>
            </label>
            
            @if (!string.IsNullOrEmpty(Model?.ProfilePictureUrl))
            {
                <form method="post" action="@Url.Action("RemoveProfilePicture", "Profile")" style="display: inline;" id="removePicForm">
                    @Html.AntiForgeryToken()
                    <button type="button" class="remove-picture-btn" title="Remove picture" onclick="showConfirm('Remove your profile picture?', function() { document.getElementById('removePicForm').submit(); }, { title: 'Remove Picture', confirmText: 'Remove', danger: true })">
                        <i class="bi bi-x"></i>
                    </button>
                </form>
            }

            <input type="file" id="profilePictureInput" name="profilePicture" accept="image/*" />
        </div>

        <div class="profile-info">
            <h2>@Model?.FirstName @Model?.LastName</h2>
            <p><i class="bi bi-at"></i> @Model?.Username</p>
            <p><i class="bi bi-envelope"></i> @Model?.Email</p>
            @if (!string.IsNullOrEmpty(Model?.PhoneNumber))
            {
                <p><i class="bi bi-telephone"></i> @Model?.PhoneNumber</p>
            }
        </div>
    </div>

    <!-- Pinned Journals -->
    @{
        var pinCount = Model?.PinnedJournals?.Count ?? 0;
    }
    <div class="section-card" id="pinnedJournalsSection">
        <h3 class="section-title">
            <i class="bi bi-pin-fill" style="color: #667eea;"></i> Pinned Journals
        </h3>
        <p class="pin-counter">
            <span id="pinCountDisplay">@pinCount</span>/3 pinned &mdash;
            Open any journal and click <strong>Pin to Profile</strong> to showcase it here.
            <a href="@Url.Action("MyJournals", "Journal")" style="color: #667eea;">My Journals →</a>
        </p>

        @if (Model?.PinnedJournals != null && Model.PinnedJournals.Any())
        {
            <div class="pinned-grid" id="pinnedGrid">
                @foreach (var journal in Model.PinnedJournals)
                {
                    <div class="pinned-card" id="pinned-card-@journal.JournalId">
                        <div class="pinned-card-header">
                            <h4 class="pinned-card-title">
                                <a href="@Url.Action("View", "Journal", new { id = journal.JournalId })" style="color: inherit; text-decoration: none;">
                                    @journal.Title
                                </a>
                            </h4>
                            <button class="unpin-btn" title="Unpin from profile" onclick="unpinJournal(@journal.JournalId)">
                                <i class="bi bi-x-circle"></i>
                            </button>
                        </div>
                        @if (!string.IsNullOrEmpty(journal.Topic))
                        {
                            <span class="pinned-topic"><i class="bi bi-tag"></i> @journal.Topic</span>
                        }
                        <p class="pinned-preview">@journal.Content</p>
                        <div class="pinned-card-footer">
                            <span><i class="bi bi-eye"></i> @journal.ViewCount</span>
                            <time datetime="@journal.CreatedAt.ToString("o")"></time>
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <div class="pinned-empty" id="pinnedEmpty">
                <i class="bi bi-pin" style="font-size: 2rem; color: rgba(102, 126, 234, 0.4); display: block; margin-bottom: 10px;"></i>
                <p style="color: var(--text-secondary); margin: 0;">No pinned journals yet.</p>
                <small style="color: var(--text-secondary);">Open a journal and click <strong>Pin to Profile</strong> to pin it here.</small>
            </div>
        }
    </div>

    <!-- Personal Information -->
    <form method="post" action="@Url.Action("UpdateProfile", "Profile")" enctype="multipart/form-data">
        @Html.AntiForgeryToken()
        <div class="section-card">
            <h3 class="section-title">
                <i class="bi bi-person-circle"></i> Personal Information
            </h3>

            <div class="form-row">
                <div class="form-group">
                    <label for="FirstName">First Name</label>
                    <input type="text" class="form-control" id="FirstName" name="FirstName" value="@Model?.FirstName" required />
                </div>
                <div class="form-group">
                    <label for="LastName">Last Name</label>
                    <input type="text" class="form-control" id="LastName" name="LastName" value="@Model?.LastName" required />
                </div>
            </div>

            <div class="form-row">
                <div class="form-group">
                    <label for="Email">Email Address</label>
                    <input type="email" class="form-control" id="Email" name="Email" value="@Model?.Email" disabled />
                    <small style="color: var(--text-secondary);">Email cannot be changed</small>
                </div>
                <div class="form-group">
                    <label for="PhoneNumber">Phone Number</label>
                    <input type="tel" class="form-control" id="PhoneNumber" name="PhoneNumber" placeholder="+1 (555) 000-0000" value="@Model?.PhoneNumber" />
                </div>
            </div>

            <div class="form-row">
                <div class="form-group">
                    <label for="Gender">Gender</label>
                    <select class="form-select" id="Gender" name="Gender">
                        <option value="Not Specified" selected="@(string.IsNullOrEmpty(Model?.Gender) || Model?.Gender == "Not Specified")">Prefer not to say</option>
                        <option value="Male" selected="@(Model?.Gender == "Male")">Male</option>
                        <option value="Female" selected="@(Model?.Gender == "Female")">Female</option>
                        <option value="Other" selected="@(Model?.Gender == "Other")">Other</option>
                    </select>
                </div>
                <div class="form-group">
                    <label for="DateOfBirth">Date of Birth</label>
                    <input type="date" class="form-control" id="DateOfBirth" name="DateOfBirth" value="@(Model?.DateOfBirth?.ToString("yyyy-MM-dd"))" />
                </div>
            </div>

            <div class="form-group">
                <label for="Bio">Bio</label>
                <textarea class="form-control" id="Bio" name="Bio" placeholder="Tell us about yourself..." maxlength="200" rows="4" style="resize: vertical;">@Model?.Bio</textarea>
                <small id="bioCounter" style="color: var(--text-secondary);">0 / 200 characters</small>
            </div>

            <div class="form-actions">
                <button type="submit" class="btn-primary">
                    <i class="bi bi-check-circle"></i> Save Changes
                </button>
            </div>
        </div>
    </form>

    <!-- Notification Settings -->
    <div class="section-card">
        <h3 class="section-title">
            <i class="bi bi-bell"></i> Notifications
        </h3>

        <p style="color: var(--text-secondary); margin-bottom: 20px;">
            Manage your email notification preferences for friends, journals, and security alerts.
        </p>

        <a href="@Url.Action("Settings", "Notification")" class="btn-primary">
            <i class="bi bi-gear"></i> Notification Settings
        </a>
    </div>

    <!-- Privacy & Safety -->
    <div class="section-card">
        <h3 class="section-title">
            <i class="bi bi-shield-lock"></i> Privacy &amp; Safety
        </h3>

        <p style="color: var(--text-secondary); margin-bottom: 20px;">
            Manage users you have blocked. Blocked users cannot view your profile or journals.
        </p>

        <a href="@Url.Action("BlockedUsers", "Profile")" class="btn-primary" style="background: rgba(244, 67, 54, 0.15); color: #f44336; border: 1px solid rgba(244, 67, 54, 0.3);">
            <i class="bi bi-ban"></i> Manage Blocked Users
        </a>
    </div>

    <!-- Danger Zone -->
    <div class="section-card" style="border-color: rgba(255, 107, 107, 0.3); background: linear-gradient(135deg, rgba(255, 107, 107, 0.05) 0%, rgba(255, 107, 107, 0.02) 100%);">
        <h3 class="section-title" style="color: #ff6b6b; border-bottom-color: rgba(255, 107, 107, 0.3);">
            <i class="bi bi-exclamation-triangle"></i> Danger Zone
        </h3>

        <p style="color: var(--text-secondary); margin-bottom: 20px;">These actions cannot be undone</p>

        <form method="post" action="@Url.Action("DeleteAccount", "Profile")" style="display: inline;" id="deleteAccountForm">
            @Html.AntiForgeryToken()
            <button type="button" class="btn-danger" onclick="showConfirm('Are you sure you want to delete your account? This action cannot be undone.', function() { document.getElementById('deleteAccountForm').submit(); }, { title: 'Delete Account', confirmText: 'Delete Permanently', danger: true })">
                <i class="bi bi-trash"></i> Delete Account
            </button>
        </form>
    </div>
</div>

<script>
// Bio character counter
const bioField = document.getElementById('Bio');
const bioCounter = document.getElementById('bioCounter');

if (bioField) {
    // Initialize counter on page load
    updateBioCounter();

    bioField.addEventListener('input', function() {
        updateBioCounter();
    });

    function updateBioCounter() {
        const length = bioField.value.length;
        bioCounter.textContent = length + ' / 200 characters';
        
        if (length > 200) {
            bioField.value = bioField.value.substring(0, 200);
            bioCounter.textContent = '200 / 200 characters';
        }
        
        // Change color when approaching limit
        if (length > 150) {
            bioCounter.style.color = '#ffa94d';
        } else if (length > 180) {
            bioCounter.style.color = '#ff6b6b';
        } else {
            bioCounter.style.color = 'var(--text-secondary)';
        }
    }
}
</script>

<script>
    // Handle profile picture file selection
    const profileInput = document.getElementById('profilePictureInput');
    const profileForm = profileInput.closest('form') || document.createElement('form');

    profileInput.addEventListener('change', function (e) {
        if (this.files && this.files.length > 0) {
            // Create a form and submit with the file
            const formData = new FormData();
            formData.append('profilePicture', this.files[0]);
            formData.append('FirstName', document.getElementById('FirstName').value);
            formData.append('LastName', document.getElementById('LastName').value);
            formData.append('PhoneNumber', document.getElementById('PhoneNumber').value);
            formData.append('Gender', document.getElementById('Gender').value);

            // Add CSRF token
            const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value;
            if (token) {
                formData.append('__RequestVerificationToken', token);
            }

            fetch('@Url.Action("UpdateProfile", "Profile")', {
                method: 'POST',
                body: formData
            })
            .then(response => {
                if (response.ok) {
                    location.reload();
                } else {
                    showToast('Error uploading profile picture', 'error');
                }
            })
            .catch(err => console.error('Error:', err));
        }
    });

    // Load saved theme from localStorage
    const savedTheme = localStorage.getItem('theme') || 'dark';
    document.documentElement.setAttribute('data-theme', savedTheme);

    // Convert <time> elements in pinned cards to local date
    document.querySelectorAll('time[datetime]').forEach(function (el) {
        var utc = new Date(el.getAttribute('datetime'));
        if (!isNaN(utc)) el.textContent = utc.toLocaleDateString(undefined, { month: 'short', day: 'numeric', year: 'numeric' });
    });

    function unpinJournal(journalId) {
        const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value;
        fetch('@Url.Action("TogglePin", "Profile")', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/x-www-form-urlencoded',
                'RequestVerificationToken': token || ''
            },
            body: `journalId=${journalId}`
        })
        .then(r => { if (!r.ok) return r.json().then(d => { throw new Error(d.message); }); return r.json(); })
        .then(() => {
            const card = document.getElementById(`pinned-card-${journalId}`);
            if (card) card.remove();
            const counter = document.getElementById('pinCountDisplay');
            if (counter) counter.textContent = Math.max(0, parseInt(counter.textContent) - 1);
            const grid = document.getElementById('pinnedGrid');
            if (grid && grid.children.length === 0) {
                grid.style.display = 'none';
                grid.insertAdjacentHTML('afterend', `<div class="pinned-empty" id="pinnedEmpty"><i class="bi bi-pin" style="font-size:2rem;color:rgba(102,126,234,0.4);display:block;margin-bottom:10px;"></i><p style="color:var(--text-secondary);margin:0;">No pinned journals yet.</p><small style="color:var(--text-secondary);">Open a journal and click <strong>Pin to Profile</strong> to pin it here.</small></div>`);
            }
            showToast('Journal unpinned from profile', 'success');
        })
        .catch(err => showToast(err.message || 'Failed to unpin', 'error'));
    }
</script>

