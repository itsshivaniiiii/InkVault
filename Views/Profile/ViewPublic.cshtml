@model InkVault.ViewModels.ProfileViewModel
@using Microsoft.AspNetCore.Identity
@inject UserManager<ApplicationUser> UserManager

@{
    ViewData["Title"] = $"{Model?.FirstName} {Model?.LastName}'s Profile";
}

<style>
    .public-profile-container {
        max-width: 600px;
        margin: 0 auto;
        animation: fadeInUp 0.8s ease;
    }

    .public-profile-header {
        background: linear-gradient(135deg, rgba(102, 126, 234, 0.15) 0%, rgba(240, 147, 251, 0.15) 100%);
        border: 1px solid rgba(102, 126, 234, 0.2);
        border-radius: 15px;
        padding: 40px 30px;
        text-align: center;
        margin-bottom: 40px;
        position: relative;
        overflow: hidden;
    }

    .public-profile-header::before {
        content: '';
        position: absolute;
        top: -50%;
        right: -10%;
        width: 300px;
        height: 300px;
        background: radial-gradient(circle, rgba(240, 147, 251, 0.1) 0%, transparent 70%);
        border-radius: 50%;
    }

    .public-profile-avatar {
        width: 150px;
        height: 150px;
        border-radius: 50%;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 3rem;
        font-weight: 700;
        color: white;
        margin: 0 auto 20px;
        border: 4px solid rgba(102, 126, 234, 0.3);
        position: relative;
        z-index: 1;
    }

    .public-profile-avatar img {
        width: 100%;
        height: 100%;
        border-radius: 50%;
        object-fit: cover;
    }

    .public-profile-name {
        font-size: 2rem;
        font-weight: 700;
        color: var(--text-primary);
        margin-bottom: 5px;
        position: relative;
        z-index: 1;
    }

    .public-profile-username {
        color: var(--text-secondary);
        font-size: 1rem;
        margin-bottom: 15px;
        position: relative;
        z-index: 1;
    }

    .public-profile-bio {
        background: rgba(102, 126, 234, 0.1);
        border: 1px solid rgba(102, 126, 234, 0.2);
        border-radius: 8px;
        padding: 15px;
        margin-top: 20px;
        color: var(--text-secondary);
        font-size: 0.95rem;
        line-height: 1.6;
        position: relative;
        z-index: 1;
    }

    .friend-status {
        display: inline-block;
        background: linear-gradient(135deg, #51cf66 0%, #37b24d 100%);
        color: white;
        padding: 8px 16px;
        border-radius: 20px;
        font-size: 0.85rem;
        font-weight: 600;
        margin-top: 15px;
        position: relative;
        z-index: 1;
    }

    .profile-stats {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 20px;
        margin-bottom: 30px;
    }

    .stat-box {
        background: linear-gradient(135deg, rgba(102, 126, 234, 0.1) 0%, rgba(118, 75, 162, 0.1) 100%);
        border: 1px solid rgba(102, 126, 234, 0.2);
        border-radius: 10px;
        padding: 20px;
        text-align: center;
        transition: all 0.3s ease;
    }

    .stat-box:hover {
        transform: translateY(-5px);
        box-shadow: 0 15px 30px rgba(102, 126, 234, 0.15);
    }

    .stat-number {
        font-size: 2rem;
        font-weight: 700;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
    }

    .stat-label {
        color: var(--text-secondary);
        font-size: 0.85rem;
        margin-top: 8px;
    }

    .profile-section {
        background: linear-gradient(135deg, rgba(102, 126, 234, 0.1) 0%, rgba(118, 75, 162, 0.1) 100%);
        border: 1px solid rgba(102, 126, 234, 0.2);
        border-radius: 12px;
        padding: 25px;
        margin-bottom: 25px;
    }

    .profile-section h3 {
        font-weight: 700;
        color: var(--text-primary);
        margin-bottom: 20px;
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .profile-section i {
        color: #667eea;
        font-size: 1.3rem;
    }

    .profile-info-item {
        display: flex;
        align-items: center;
        gap: 15px;
        padding: 12px 0;
        border-bottom: 1px solid rgba(102, 126, 234, 0.1);
    }

    .profile-info-item:last-child {
        border-bottom: none;
    }

    .profile-info-label {
        color: var(--text-secondary);
        font-weight: 600;
        min-width: 100px;
    }

    .profile-info-value {
        color: var(--text-primary);
    }

    .action-button {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
        padding: 12px 30px;
        border: none;
        border-radius: 8px;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.3s ease;
        display: inline-flex;
        align-items: center;
        gap: 8px;
    }

    .action-button:hover {
        transform: translateY(-3px);
        box-shadow: 0 15px 35px rgba(102, 126, 234, 0.4);
        color: white;
        text-decoration: none;
    }

    /* Block button styles */
    .block-btn {
        background: rgba(244, 67, 54, 0.15);
        color: #f44336;
        padding: 10px 20px;
        border: 1px solid rgba(244, 67, 54, 0.3);
        border-radius: 8px;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.3s ease;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        font-size: 0.9rem;
    }

    .block-btn:hover {
        background: rgba(244, 67, 54, 0.25);
        color: #f44336;
    }

    .unblock-btn {
        background: rgba(102, 126, 234, 0.15);
        color: #667eea;
        padding: 10px 20px;
        border: 1px solid rgba(102, 126, 234, 0.3);
        border-radius: 8px;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.3s ease;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        font-size: 0.9rem;
    }

    .unblock-btn:hover {
        background: rgba(102, 126, 234, 0.25);
        color: #667eea;
    }

    .no-journals {
        text-align: center;
        padding: 40px 20px;
        color: var(--text-secondary);
    }

    .no-journals i {
        font-size: 3rem;
        opacity: 0.5;
        display: block;
        margin-bottom: 15px;
    }

    .pinned-section {
        background: linear-gradient(135deg, rgba(102, 126, 234, 0.1) 0%, rgba(118, 75, 162, 0.1) 100%);
        border: 1px solid rgba(102, 126, 234, 0.2);
        border-radius: 12px;
        padding: 25px;
        margin-bottom: 25px;
    }

    .pinned-section-title {
        font-size: 1.1rem;
        font-weight: 700;
        margin-bottom: 18px;
        padding-bottom: 12px;
        border-bottom: 2px solid rgba(102, 126, 234, 0.2);
        color: var(--text-primary);
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .pinned-pub-card {
        background: rgba(255, 255, 255, 0.04);
        border: 1px solid rgba(102, 126, 234, 0.15);
        border-radius: 8px;
        padding: 16px;
        margin-bottom: 14px;
        transition: all 0.3s ease;
        text-decoration: none;
        display: block;
        color: inherit;
    }

    .pinned-pub-card:hover {
        border-color: rgba(102, 126, 234, 0.4);
        background: rgba(102, 126, 234, 0.08);
        transform: translateY(-2px);
        box-shadow: 0 6px 16px rgba(102, 126, 234, 0.12);
        color: inherit;
        text-decoration: none;
    }

    .pinned-pub-title {
        font-size: 1rem;
        font-weight: 700;
        color: var(--text-primary);
        margin-bottom: 6px;
    }

    .pinned-pub-preview {
        font-size: 0.85rem;
        color: var(--text-secondary);
        line-height: 1.5;
        margin-bottom: 10px;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    .pinned-pub-footer {
        display: flex;
        gap: 15px;
        font-size: 0.8rem;
        color: var(--text-secondary);
    }

    [data-theme="light"] .pinned-pub-card {
        background: #ffffff;
        border-color: rgba(102, 126, 234, 0.1);
    }
</style>

<div class="public-profile-container">
    <!-- Profile Header -->
    <div class="public-profile-header">
        <div class="public-profile-avatar">
            @if (!string.IsNullOrEmpty(Model?.ProfilePictureUrl))
            {
                <img src="@Model.ProfilePictureUrl" alt="@Model.FirstName @Model.LastName" />
            }
            else
            {
                <span>@Model?.FirstName?.FirstOrDefault()@Model?.LastName?.FirstOrDefault()</span>
            }
        </div>

        <div class="public-profile-name">@Model?.FirstName @Model?.LastName</div>
        <div class="public-profile-username">@Model?.Username</div>

        @if (Model?.AreFriends ?? false)
        {
            <div class="friend-status">
                <i class="bi bi-check-circle"></i> Friends
            </div>
        }

        @if (!string.IsNullOrEmpty(Model?.Bio))
        {
            <div class="public-profile-bio">
                @Model.Bio
            </div>
        }
    </div>

    <!-- Profile Information Section -->
    <div class="profile-section">
        <h3>
            <i class="bi bi-info-circle"></i> Profile Information
        </h3>

        @if (Model?.DateOfBirth.HasValue ?? false)
        {
            <div class="profile-info-item">
                <span class="profile-info-label">Date of Birth</span>
                <span class="profile-info-value">@Model.DateOfBirth?.ToString("MMMM dd, yyyy")</span>
            </div>
        }

        <div class="profile-info-item">
            <span class="profile-info-label">Member Since</span>
            <span class="profile-info-value"><time datetime="@Model?.CreatedAt.ToString("o")" data-format="month-year"></time></span>
        </div>
    </div>

    <!-- Action Buttons (if viewing another user) -->
    @{
        var currentUser = await UserManager.GetUserAsync(User);
        if (currentUser != null && currentUser.Id != Model?.UserId)
        {
            <div style="text-align: center; margin-bottom: 30px; display: flex; justify-content: center; gap: 12px; flex-wrap: wrap;">
                @if (Model?.IsBlockedByMe ?? false)
                {
                    <form id="unblockUserForm" method="post" asp-action="UnblockUser" asp-controller="Profile"
                          style="display:inline;"
                          data-user-name="@Model?.FirstName @Model?.LastName">
                        <input type="hidden" name="userId" value="@Model?.UserId" />
                        @Html.AntiForgeryToken()
                        <button type="button" class="unblock-btn" onclick="confirmUnblock()">
                            <i class="bi bi-slash-circle"></i> Unblock User
                        </button>
                    </form>
                }
                else
                {
                    @if (Model?.AreFriends ?? false)
                    {
                        <button class="action-button" disabled>
                            <i class="bi bi-check-circle"></i> Already Friends
                        </button>
                    }
                    else
                    {
                        @Html.AntiForgeryToken()
                        <button type="button" class="action-button" id="addFriendBtn"
                            onclick="sendFriendRequestFromProfile('@Model?.UserId', '@Model?.FirstName @Model?.LastName')">
                            <i class="bi bi-person-plus"></i> Add Friend
                        </button>
                    }
                    <form id="blockUserForm" method="post" asp-action="BlockUser" asp-controller="Profile"
                          style="display:inline;"
                          data-user-name="@Model?.FirstName @Model?.LastName">
                        <input type="hidden" name="userId" value="@Model?.UserId" />
                        @Html.AntiForgeryToken()
                        <button type="button" class="block-btn" onclick="confirmBlock()">
                            <i class="bi bi-ban"></i> Block
                        </button>
                    </form>
                }
            </div>
        }
    }

    <!-- Pinned Journals Section -->
    @if (Model?.PinnedJournals != null && Model.PinnedJournals.Any())
    {
        <div class="pinned-section">
            <div class="pinned-section-title">
                <i class="bi bi-pin-fill" style="color: #667eea;"></i> Pinned Journals
            </div>
            @foreach (var journal in Model.PinnedJournals)
            {
                <a href="@Url.Action("View", "Journal", new { id = journal.JournalId, fromUserProfile = true, userProfileId = Model.UserId })" class="pinned-pub-card">
                    <div class="pinned-pub-title">@journal.Title</div>
                    @if (!string.IsNullOrEmpty(journal.Content))
                    {
                        <div class="pinned-pub-preview">@journal.Content</div>
                    }
                    <div class="pinned-pub-footer">
                        @if (!string.IsNullOrEmpty(journal.Topic))
                        {
                            <span><i class="bi bi-tag"></i> @journal.Topic</span>
                        }
                        <span><i class="bi bi-eye"></i> @journal.ViewCount</span>
                        <span><time datetime="@journal.CreatedAt.ToString("o")"></time></span>
                    </div>
                </a>
            }
        </div>
    }

    <!-- Public Journals Section -->
    <div class="profile-section">
        <h3>
            <i class="bi bi-book"></i> Public Journals
        </h3>

        @if (Model?.PublicJournalCount > 0)
        {
            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 15px; margin-top: 15px;">
                <div class="stat-box" style="text-align: center;">
                    <div class="stat-number">@Model.PublicJournalCount</div>
                    <div class="stat-label">Public Journals</div>
                </div>
                <div style="background: linear-gradient(135deg, rgba(102, 126, 234, 0.1) 0%, rgba(118, 75, 162, 0.1) 100%); border: 1px solid rgba(102, 126, 234, 0.2); border-radius: 10px; padding: 20px; text-align: center;">
                    <p style="color: var(--text-secondary); font-size: 0.9rem; margin: 0;">
                        <i class="bi bi-globe"></i> This user has shared <strong>@Model.PublicJournalCount</strong> journal@(Model.PublicJournalCount != 1 ? "s" : "") publicly
                    </p>
                </div>
            </div>

            <a href="@Url.Action("ViewUserJournals", "Profile", new { userId = Model?.UserId, fromFriends = ViewBag.FromFriends ?? false })" 
               class="action-button" 
               style="display: inline-flex; margin-top: 20px;"
               title="View @Model?.FirstName's journals">
                <i class="bi bi-journal-text"></i> View Journals
            </a>
        }
        else
        {
            <div style="text-align: center; padding: 30px 20px; background: rgba(102, 126, 234, 0.05); border-radius: 8px; margin-top: 15px;">
                <i class="bi bi-book" style="font-size: 2rem; opacity: 0.5; display: block; margin-bottom: 10px;"></i>
                <p style="color: var(--text-secondary); margin: 0;">No public journals shared yet</p>
                <small style="color: var(--text-secondary);">Only public journals are shown</small>

                <!-- Disabled Button for No Journals -->
                <button class="action-button" 
                        style="display: inline-flex; margin-top: 15px; opacity: 0.5; cursor: not-allowed; background: rgba(102, 126, 234, 0.3);" 
                        disabled 
                        title="@Model?.FirstName has no public journals available">
                    <i class="bi bi-journal-text"></i> View Journals
                </button>
            </div>
        }
    </div>

    <!-- Empty State -->
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            document.querySelectorAll('time[datetime]').forEach(function (el) {
                var utc = new Date(el.getAttribute('datetime'));
                if (!isNaN(utc)) el.textContent = utc.toLocaleDateString(undefined, { month: 'short', day: 'numeric', year: 'numeric' });
            });
        });

        function confirmBlock() {
            var form = document.getElementById('blockUserForm');
            var userName = form ? form.getAttribute('data-user-name') : '';
            showConfirm(
                'Block ' + userName + '? They will be removed from your friends and won\'t be able to see your profile.',
                function() { document.getElementById('blockUserForm').submit(); },
                { title: 'Block User', confirmText: 'Block', danger: true }
            );
        }

        function confirmUnblock() {
            var form = document.getElementById('unblockUserForm');
            var userName = form ? form.getAttribute('data-user-name') : '';
            showConfirm(
                'Unblock ' + userName + '? They will be able to view your profile again.',
                function() { document.getElementById('unblockUserForm').submit(); },
                { title: 'Unblock User', confirmText: 'Unblock' }
            );
        }

        function sendFriendRequestFromProfile(receiverId, userName) {
            showConfirm('Send friend request to ' + userName + '?', function() {
                var btn = document.getElementById('addFriendBtn');
                btn.disabled = true;
                btn.innerHTML = '<i class="bi bi-hourglass-split"></i> Sending...';

                var csrfToken = document.querySelector('input[name="__RequestVerificationToken"]')?.value || '';

                fetch('/Friends/SendRequest', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/x-www-form-urlencoded',
                        'X-Requested-With': 'XMLHttpRequest'
                    },
                    body: 'receiverId=' + encodeURIComponent(receiverId) +
                          '&__RequestVerificationToken=' + encodeURIComponent(csrfToken)
                })
                .then(function(response) {
                    return response.json().then(function(data) { return { ok: response.ok, data: data }; });
                })
                .then(function(result) {
                    if (!result.ok) throw new Error(result.data.message || 'Failed to send request');
                    showToast('Friend request sent to ' + userName + '!', 'success');
                    btn.innerHTML = '<i class="bi bi-clock"></i> Request Sent';
                    btn.style.opacity = '0.7';
                    btn.disabled = true;
                    btn.onclick = null;
                })
                .catch(function(error) {
                    showToast(error.message || 'Error sending friend request', 'error');
                    btn.disabled = false;
                    btn.innerHTML = '<i class="bi bi-person-plus"></i> Add Friend';
                });
            }, { title: 'Add Friend', confirmText: 'Send Request' });
        }
    </script>
}
