@model InkVault.ViewModels.NotificationInboxViewModel
@using InkVault.Models

@{
    ViewData["Title"] = "Notifications";
}

<style>
    .inbox-container {
        max-width: 820px;
        margin: 0 auto;
        padding: 20px;
        animation: fadeInUp 0.8s ease;
    }

    .back-link-notif {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 10px 20px;
        background: rgba(102, 126, 234, 0.2);
        color: #667eea;
        border: 1px solid rgba(102, 126, 234, 0.3);
        border-radius: 6px;
        text-decoration: none;
        font-weight: 600;
        transition: all 0.3s;
        margin-bottom: 24px;
    }
    .back-link-notif:hover {
        background: rgba(102, 126, 234, 0.3);
        color: #667eea;
        text-decoration: none;
    }

    .inbox-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 30px;
        padding-bottom: 18px;
        border-bottom: 2px solid rgba(102, 126, 234, 0.3);
        flex-wrap: wrap;
        gap: 12px;
    }
    .inbox-header-left { display: flex; align-items: center; gap: 14px; }
    .inbox-header h1 {
        font-size: 2rem;
        font-weight: 700;
        margin: 0;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
    }

    .unread-badge {
        background: linear-gradient(135deg, #667eea, #764ba2);
        color: #fff;
        border-radius: 20px;
        padding: 4px 14px;
        font-size: .85rem;
        font-weight: 700;
    }
    .btn-mark-all {
        background: rgba(102, 126, 234, 0.15);
        color: #667eea;
        border: 1px solid rgba(102, 126, 234, 0.3);
        border-radius: 8px;
        padding: 8px 18px;
        font-weight: 600;
        font-size: .9rem;
        cursor: pointer;
        transition: all .3s;
        display: inline-flex;
        align-items: center;
        gap: 6px;
        text-decoration: none;
    }
    .btn-mark-all:hover {
        background: rgba(102, 126, 234, 0.28);
        color: #667eea;
        text-decoration: none;
    }

    /* Tabs */
    .notif-tabs {
        display: flex;
        gap: 6px;
        margin-bottom: 24px;
        flex-wrap: wrap;
    }
    .notif-tab {
        padding: 9px 20px;
        border-radius: 20px;
        font-weight: 600;
        font-size: .9rem;
        cursor: pointer;
        border: 1px solid rgba(102, 126, 234, 0.25);
        background: rgba(102, 126, 234, 0.08);
        color: var(--text-secondary);
        transition: all .25s;
        user-select: none;
    }
    .notif-tab.active, .notif-tab:hover {
        background: linear-gradient(135deg, #667eea, #764ba2);
        color: #fff;
        border-color: transparent;
    }

    /* Panels */
    .tab-panel { display: none; }
    .tab-panel.active { display: block; }

    /* Notification card */
    .notif-card {
        display: flex;
        align-items: flex-start;
        gap: 14px;
        padding: 16px 18px;
        border-radius: 10px;
        border: 1px solid rgba(102, 126, 234, 0.15);
        background: rgba(102, 126, 234, 0.06);
        margin-bottom: 10px;
        transition: all .25s;
        position: relative;
    }
    .notif-card:hover {
        background: rgba(102, 126, 234, 0.12);
        border-color: rgba(102, 126, 234, 0.3);
    }
    .notif-card.unread {
        border-left: 4px solid #667eea;
        background: rgba(102, 126, 234, 0.11);
    }
    .notif-card.unread::after {
        content: '';
        position: absolute;
        top: 14px;
        right: 16px;
        width: 9px;
        height: 9px;
        border-radius: 50%;
        background: linear-gradient(135deg, #667eea, #764ba2);
    }

    .notif-avatar {
        width: 44px;
        height: 44px;
        border-radius: 50%;
        flex-shrink: 0;
        object-fit: cover;
        border: 2px solid rgba(102, 126, 234, 0.35);
    }
    .notif-avatar-initials {
        width: 44px;
        height: 44px;
        border-radius: 50%;
        flex-shrink: 0;
        background: linear-gradient(135deg, #667eea, #764ba2);
        color: #fff;
        font-weight: 700;
        font-size: .95rem;
        display: flex;
        align-items: center;
        justify-content: center;
    }
    .notif-icon-wrap {
        width: 44px;
        height: 44px;
        border-radius: 50%;
        flex-shrink: 0;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.2rem;
    }

    .notif-body { flex: 1; min-width: 0; }
    .notif-message {
        color: var(--text-primary);
        font-size: .95rem;
        line-height: 1.5;
        margin: 0 0 4px;
        word-break: break-word;
    }
    .notif-time { color: var(--text-secondary); font-size: .8rem; }

    .notif-actions {
        display: flex;
        align-items: center;
        gap: 8px;
        flex-shrink: 0;
    }
    .btn-go-notif {
        padding: 5px 12px;
        border-radius: 6px;
        font-size: .8rem;
        font-weight: 600;
        background: linear-gradient(135deg, #667eea, #764ba2);
        color: #fff;
        border: none;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 4px;
        white-space: nowrap;
    }
    .btn-go-notif:hover { opacity: .85; color: #fff; text-decoration: none; }
    .btn-read-notif {
        padding: 5px 12px;
        border-radius: 6px;
        font-size: .8rem;
        font-weight: 600;
        background: rgba(102, 126, 234, 0.15);
        color: #667eea;
        border: 1px solid rgba(102, 126, 234, 0.3);
        cursor: pointer;
        transition: all .2s;
        white-space: nowrap;
    }
    .btn-read-notif:hover { background: rgba(102, 126, 234, 0.3); }

    .section-label {
        font-size: .8rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: .08em;
        color: var(--text-secondary);
        margin: 20px 0 10px;
        padding-bottom: 6px;
        border-bottom: 1px solid rgba(102, 126, 234, 0.15);
    }
    .section-label:first-child { margin-top: 0; }

    .empty-state {
        text-align: center;
        padding: 60px 20px;
        color: var(--text-secondary);
    }
    .empty-state i {
        font-size: 3rem;
        color: rgba(102, 126, 234, 0.4);
        margin-bottom: 14px;
        display: block;
    }

    [data-theme="light"] .notif-card { background: #fff; border-color: rgba(102, 126, 234, 0.12); }
    [data-theme="light"] .notif-card:hover { background: rgba(102, 126, 234, 0.05); }
    [data-theme="light"] .notif-card.unread { background: rgba(102, 126, 234, 0.07); }

    @@media (max-width: 600px) {
        .inbox-header { flex-direction: column; align-items: flex-start; }
        .notif-card { flex-wrap: wrap; }
        .notif-actions { width: 100%; justify-content: flex-end; margin-top: 8px; }
        .notif-tab { padding: 7px 14px; font-size: .82rem; }
    }
</style>

<div class="inbox-container">

    <a href="@Url.Action("Index", "Profile")" class="back-link-notif">
        <i class="bi bi-arrow-left"></i> Back to Profile
    </a>

    <div class="inbox-header">
        <div class="inbox-header-left">
            <i class="bi bi-bell-fill" style="font-size:2.2rem;color:#667eea;"></i>
            <h1>Notifications</h1>
            @if (Model.UnreadCount > 0)
            {
                <span class="unread-badge">@Model.UnreadCount unread</span>
            }
        </div>
        @if (Model.AllNotifications.Any())
        {
            <form method="post" action="@Url.Action("MarkAllAsRead","Notification")">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn-mark-all">
                    <i class="bi bi-check2-all"></i> Mark all as read
                </button>
            </form>
        }
    </div>

    <!-- Tab navigation -->
    <div class="notif-tabs">
        <div class="notif-tab active" data-tab="all">
            <i class="bi bi-bell"></i> All
            @if (Model.AllNotifications.Count > 0)
            {
                <span>(@Model.AllNotifications.Count)</span>
            }
        </div>
        <div class="notif-tab" data-tab="likes-comments">
            <i class="bi bi-heart"></i> Likes &amp; Comments
            @{ var lcCount = Model.LikesAndComments.Count(); }
            @if (lcCount > 0) { <span>(@lcCount)</span> }
        </div>
        <div class="notif-tab" data-tab="friends">
            <i class="bi bi-people"></i> Friends
            @{ var frCount = Model.FriendNotifications.Count(); }
            @if (frCount > 0) { <span>(@frCount)</span> }
        </div>
        <div class="notif-tab" data-tab="journals">
            <i class="bi bi-journal-text"></i> Journals
            @{ var jrCount = Model.JournalNotifications.Count(); }
            @if (jrCount > 0) { <span>(@jrCount)</span> }
        </div>
    </div>

    <!-- ALL notifications -->
    <div class="tab-panel active" id="tab-all">
        @if (!Model.AllNotifications.Any())
        {
            <div class="empty-state">
                <i class="bi bi-bell-slash"></i>
                <p>No notifications yet. Come back after some activity!</p>
            </div>
        }
        else
        {
            foreach (var n in Model.AllNotifications)
            {
                await Html.RenderPartialAsync("_NotificationCard", n);
            }
        }
    </div>

    <!-- LIKES & COMMENTS -->
    <div class="tab-panel" id="tab-likes-comments">
        @{
            var likeSec    = Model.AllNotifications.Where(n => n.Type == NotificationType.LikeReceived || n.Type == NotificationType.LikeRemoved).ToList();
            var commentSec = Model.AllNotifications.Where(n => n.Type == NotificationType.CommentReceived || n.Type == NotificationType.CommentDeleted).ToList();
        }
        @if (!likeSec.Any() && !commentSec.Any())
        {
            <div class="empty-state"><i class="bi bi-heart"></i><p>No likes or comment activity yet.</p></div>
        }
        else
        {
            if (likeSec.Any())
            {
                <div class="section-label"><i class="bi bi-heart-fill" style="color:#e91e63;"></i> Likes</div>
                foreach (var n in likeSec) { await Html.RenderPartialAsync("_NotificationCard", n); }
            }
            if (commentSec.Any())
            {
                <div class="section-label"><i class="bi bi-chat-dots-fill" style="color:#667eea;"></i> Comments</div>
                foreach (var n in commentSec) { await Html.RenderPartialAsync("_NotificationCard", n); }
            }
        }
    </div>

    <!-- FRIENDS -->
    <div class="tab-panel" id="tab-friends">
        @{
            var reqReceived  = Model.AllNotifications.Where(n => n.Type == NotificationType.FriendRequestReceived).ToList();
            var reqAccepted  = Model.AllNotifications.Where(n => n.Type == NotificationType.FriendRequestAccepted).ToList();
            var reqDeclined  = Model.AllNotifications.Where(n => n.Type == NotificationType.FriendRequestDeclined).ToList();
            var reqWithdrawn = Model.AllNotifications.Where(n => n.Type == NotificationType.FriendRequestWithdrawn).ToList();
            var friendRemoved = Model.AllNotifications.Where(n => n.Type == NotificationType.FriendRemoved).ToList();
        }
        @if (!Model.FriendNotifications.Any())
        {
            <div class="empty-state"><i class="bi bi-people"></i><p>No friend activity yet.</p></div>
        }
        else
        {
            if (reqReceived.Any())
            {
                <div class="section-label"><i class="bi bi-person-plus-fill" style="color:#4caf50;"></i> Requests Received</div>
                foreach (var n in reqReceived) { await Html.RenderPartialAsync("_NotificationCard", n); }
            }
            if (reqAccepted.Any())
            {
                <div class="section-label"><i class="bi bi-person-check-fill" style="color:#4caf50;"></i> Requests Accepted</div>
                foreach (var n in reqAccepted) { await Html.RenderPartialAsync("_NotificationCard", n); }
            }
            if (reqDeclined.Any())
            {
                <div class="section-label"><i class="bi bi-person-x-fill" style="color:#f44336;"></i> Requests Declined</div>
                foreach (var n in reqDeclined) { await Html.RenderPartialAsync("_NotificationCard", n); }
            }
            if (reqWithdrawn.Any())
            {
                <div class="section-label"><i class="bi bi-person-dash" style="color:#ff9800;"></i> Requests Withdrawn</div>
                foreach (var n in reqWithdrawn) { await Html.RenderPartialAsync("_NotificationCard", n); }
            }
            if (friendRemoved.Any())
            {
                <div class="section-label"><i class="bi bi-person-x" style="color:#f44336;"></i> Removed</div>
                foreach (var n in friendRemoved) { await Html.RenderPartialAsync("_NotificationCard", n); }
            }
        }
    </div>

    <!-- JOURNALS -->
    <div class="tab-panel" id="tab-journals">
        @{
            var refSec = Model.AllNotifications.Where(n => n.Type == NotificationType.JournalReferenced).ToList();
            var pubSec = Model.AllNotifications.Where(n => n.Type == NotificationType.JournalPublished).ToList();
            var ftSec  = Model.AllNotifications.Where(n => n.Type == NotificationType.FullTextRequested).ToList();
        }
        @if (!refSec.Any() && !pubSec.Any() && !ftSec.Any())
        {
            <div class="empty-state"><i class="bi bi-journal-text"></i><p>No journal activity yet.</p></div>
        }
        else
        {
            if (refSec.Any())
            {
                <div class="section-label"><i class="bi bi-quote" style="color:#764ba2;"></i> References</div>
                foreach (var n in refSec) { await Html.RenderPartialAsync("_NotificationCard", n); }
            }
            if (pubSec.Any())
            {
                <div class="section-label"><i class="bi bi-journal-text" style="color:#667eea;"></i> New Journals</div>
                foreach (var n in pubSec) { await Html.RenderPartialAsync("_NotificationCard", n); }
            }
            if (ftSec.Any())
            {
                <div class="section-label"><i class="bi bi-file-text" style="color:#ff9800;"></i> Full-Text Requests</div>
                foreach (var n in ftSec) { await Html.RenderPartialAsync("_NotificationCard", n); }
            }
        }
    </div>

</div>

@section Scripts {
<script>
    // Tab switching
    document.querySelectorAll('.notif-tab').forEach(tab => {
        tab.addEventListener('click', () => {
            document.querySelectorAll('.notif-tab').forEach(t => t.classList.remove('active'));
            document.querySelectorAll('.tab-panel').forEach(p => p.classList.remove('active'));
            tab.classList.add('active');
            document.getElementById('tab-' + tab.dataset.tab).classList.add('active');
        });
    });

    // Mark single notification as read (AJAX, no page reload)
    async function markRead(id, btn) {
        const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value ?? '';
        try {
            const res = await fetch('@Url.Action("MarkAsRead","Notification")', {
                method: 'POST',
                headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                body: `id=${id}&__RequestVerificationToken=${encodeURIComponent(token)}`
            });
            if (res.ok) {
                const card = btn.closest('.notif-card');
                card.classList.remove('unread');
                btn.remove();
                // Refresh the bell badge
                if (typeof loadNotifBadge === 'function') loadNotifBadge();
            }
        } catch {}
    }
</script>
}
