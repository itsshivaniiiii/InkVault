# ===========================================
# .dockerignore for InkVault
# ===========================================

# Git
.git
.gitignore
.gitattributes
.github

# IDE
.vs/
.vscode/
.idea/
*.user
*.suo

# Build outputs
bin/
obj/
out/
publish/

# NuGet
*.nupkg
packages/

# Docs
*.md

# Logs
*.log
Logs/

# Sensitive / local config
appsettings.Development.json
appsettings.Local.json
appsettings.*.local.json
appsettings.example.json
secrets.json

# Database files
*.db
*.sqlite
*.sql

# Python / scripts
.venv/
venv/
*.py
*.ps1
*.sh

# Dev artifacts
*_NEW.cs
*_OLD.cs
Utilities/EmailDiagnostic.cs
EMAIL_DIAGNOSTIC_INSTRUCTIONS.txt

# Docker (avoid recursive)
Dockerfile*
docker-compose*
.dockerignore
render.yaml

# Temp
*.tmp
*.temp
*.bak
*.swp
*~

# OS files
.DS_Store
Thumbs.db
Desktop.ini

# SQL Server files
*.mdf
*.ldf
*.ndf

# Node (if any frontend build)
node_modules/
npm-debug.log
yarn-error.log

# GitHub
.github/
